{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://loa.local/schemas/openrouter-response-v1.json",
  "title": "OpenRouter chat-completion response v1 (observed contract)",
  "description": "OpenRouter chat-completion response shape as observed during the §14 spike. NOT a formal guarantee from OpenRouter — canary-monitored per SDD §12.3. OpenAIAdapter validates against this before extracting annotations[]; validation failure → GROUNDING_MALFORMED + fail to next tier in failover chain.",
  "type": "object",
  "required": ["choices"],
  "additionalProperties": true,
  "properties": {
    "id": {"type": "string"},
    "object": {"type": "string"},
    "created": {"type": "integer"},
    "model": {"type": "string"},
    "choices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["message"],
        "additionalProperties": true,
        "properties": {
          "index": {"type": "integer", "minimum": 0},
          "finish_reason": {"type": ["string", "null"]},
          "message": {
            "type": "object",
            "required": ["role"],
            "additionalProperties": true,
            "properties": {
              "role": {"type": "string"},
              "content": {"type": ["string", "null"]},
              "annotations": {
                "type": "array",
                "description": "Observed-only surface for :online grounded responses. Each entry carries a url_citation block with title/url/snippet. Missing/empty on non-grounded calls.",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "type": {"type": "string"},
                    "url_citation": {
                      "type": "object",
                      "required": ["url"],
                      "additionalProperties": true,
                      "properties": {
                        "url": {"type": "string"},
                        "title": {"type": "string"},
                        "content": {"type": "string"},
                        "start_index": {"type": "integer", "minimum": 0},
                        "end_index": {"type": "integer", "minimum": 0}
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "prompt_tokens": {"type": "integer", "minimum": 0},
        "completion_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0}
      }
    }
  }
}
